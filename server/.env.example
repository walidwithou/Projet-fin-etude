# Database connection
#
# Required query-string parameters for a Neon / serverless Postgres host:
#   sslmode=require        – Neon requires TLS. Use require (encrypt, no
#                            cert pinning) for most apps. Use verify-full
#                            only if you pin Neon's root CA bundle.
#   connect_timeout=30     – Prisma's default 5s is too short for Neon
#                            free-tier computes, which auto-suspend
#                            after ~5min of inactivity. The first
#                            connection after a suspend can take
#                            5-30s while the compute wakes up. Raising
#                            this eliminates the "Can't reach database
#                            server" cold-start error.
#   connection_limit=5     – Keep the pool small enough to stay under
#                            Neon's per-branch connection cap (max 100
#                            in pooled mode, often much less on free
#                            tier). 5 is a safe default for a single
#                            Node process.
#   pool_timeout=30        – How long a request will wait for a free
#                            pool slot before failing. Must be >=
#                            connect_timeout to survive a wake-up.
#
# The `channel_binding=require` parameter that Neon shows in its
# dashboard connection snippet is OPTIONAL on the server side. Removing
# it does NOT weaken TLS — the connection is still encrypted — it only
# disables the SCRAM channel-binding defense-in-depth. We drop it
# because the underlying TLS provider on some Windows hosts (SChannel)
# cannot export the channel-binding material that Node's TLS layer
# expects, which produced the same "Can't reach database server"
# symptom on first connection.
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require&connect_timeout=30&connection_limit=5&pool_timeout=30"

# Server configuration
PORT=5000
NODE_ENV=development

# Client URL for CORS
CLIENT_URL=http://localhost:3000

# JWT configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Filebase Decentralized Object Storage (S3-compatible)
FILEBASE_ENDPOINT=https://s3.filebase.com
FILEBASE_REGION=us-east-1
FILEBASE_BUCKET=your-filebase-bucket-name
FILEBASE_ACCESS_KEY_ID=your_access_key_id
FILEBASE_SECRET_ACCESS_KEY=your_secret_access_key
SIGNED_URL_EXPIRY_SECONDS=3600

