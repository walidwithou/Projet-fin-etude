generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id
  name             String
  email            String     @unique
  emailVerified    Boolean    @default(false)
  image            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  role             UserRole   @default(PATIENT)
  accounts         Account[]
  sentMessages     Message[]  @relation("TherapistMessages")
  receivedMessages Message[]  @relation("PatientMessages")
  patient          Patient?
  sessions         Session[]
  therapist        Therapist?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

/// Available consultation modes
model ConsultationMode {
  id         String                      @id @default(cuid())
  code       String                      @unique
  label      String
  patients   PatientConsultationMode[]
  therapists TherapistConsultationMode[]

  @@map("consultation_mode")
}

/// Available time slots
model TimeSlot {
  id         String              @id @default(cuid())
  code       String              @unique
  label      String
  patients   PatientTimeSlot[]
  therapists TherapistTimeSlot[]

  @@map("time_slot")
}

/// Available languages
model Language {
  id         String              @id @default(cuid())
  code       String              @unique
  label      String
  patients   PatientLanguage[]
  therapists TherapistLanguage[]

  @@map("language")
}

/// Available pathologies/issues
model Pathology {
  id         String               @id @default(cuid())
  code       String               @unique
  label      String
  patients   PatientPathology[]
  therapists TherapistPathology[]

  @@map("pathology")
}

/// Target audience types (therapist specialization)
model PublicType {
  id         String                @id @default(cuid())
  code       String                @unique
  label      String
  therapists TherapistPublicType[]

  @@map("public_type")
}

/// Patient Profile
model Patient {
  id                   String                    @id @default(cuid())
  userId               String                    @unique
  dateOfBirth          DateTime?                 @db.Date
  gender               String?
  phone                String?
  address              String?
  wilaya               String?
  emergencyContact     String?
  emergencyPhone       String?
  preferredLanguage    String?                   @default("ar")
  onboardingCompleted  Boolean                   @default(false)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  currentTherapistid   String?
  genrePref            GenrePref?
  sensibilitePatient   SensibilitePatient?
  experiencePassee     ExperiencePassee?
  attentesTherapie     AttentesTherapie?
  questionnaireDataRaw Json?                     @map("questionnaire_data_raw")
  appointments         Appointment[]
  currentTherapist     Therapist?                @relation(fields: [currentTherapistid], references: [id])
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultationModes    PatientConsultationMode[]
  languages            PatientLanguage[]
  pathologies          PatientPathology[]
  timeSlots            PatientTimeSlot[]
  therapistHistory     TherapistHistory[]

  @@map("patient")
}

/// Therapist Profile
model Therapist {
  id                    String                       @id @default(cuid())
  userId                String                       @unique
  gender                String?
  bio                   String?
  profilePhotoUrl       String?
  hourlyRate            Decimal?                     @db.Decimal(10, 2)
  currency              String?                      @default("DZD")
  availability          Json?
  acceptingNewPatients  Boolean                      @default(true)
  rating                Decimal?                     @db.Decimal(3, 2)
  totalReviews          Int                          @default(0)
  verificationStatus    String                       @default("pending")
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  sensibiliteTherapeute SensibiliteTherapeute?
  approcheTherapeute    ApprocheTherapeute?
  appointments          Appointment[]
  documentFiles         Document[]                   @relation("TherapistDocuments")
  patients              Patient[]
  user                  User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableTimeSlots    TherapistAvailableTimeSlot[]
  consultationModes     TherapistConsultationMode[]
  patientHistory        TherapistHistory[]
  languages             TherapistLanguage[]
  pathologies           TherapistPathology[]
  publicTypes           TherapistPublicType[]
  timeSlots             TherapistTimeSlot[]

  @@map("therapist")
}

/// Represents an uploaded document (diploma, certificate, etc.)
/// Files are stored in Filebase (S3-compatible) decentralized storage.
/// The database stores metadata + the cloud object key.
/// Secure retrieval uses S3 presigned URLs — never routes file binaries
/// through the Express server.
model Document {
  id              String    @id @default(cuid())
  ownerId         String
  ownerRole       String    @default("therapist")
  originalName    String
  mimeType        String
  fileSize        Int
  objectKey       String    @unique
  bucketName      String
  storageProvider String    @default("filebase")
  documentType    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  therapist       Therapist @relation("TherapistDocuments", fields: [ownerId], references: [userId], onDelete: Cascade, map: "document_therapist_fkey")

  @@index([ownerId, ownerRole])
  @@index([documentType])
  @@index([createdAt])
  @@map("document")
}

/// Patient - Consultation Mode (many-to-many)
model PatientConsultationMode {
  id                 String           @id @default(cuid())
  patientId          String
  consultationModeId String
  consultationMode   ConsultationMode @relation(fields: [consultationModeId], references: [id], onDelete: Cascade)
  patient            Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, consultationModeId])
  @@map("patient_consultation_mode")
}

/// Therapist - Consultation Mode (many-to-many)
model TherapistConsultationMode {
  id                 String           @id @default(cuid())
  therapistId        String
  consultationModeId String
  consultationMode   ConsultationMode @relation(fields: [consultationModeId], references: [id], onDelete: Cascade)
  therapist          Therapist        @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, consultationModeId])
  @@map("therapist_consultation_mode")
}

/// Patient - Time Slot (many-to-many)
model PatientTimeSlot {
  id         String   @id @default(cuid())
  patientId  String
  timeSlotId String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  timeSlot   TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  @@unique([patientId, timeSlotId])
  @@map("patient_time_slot")
}

/// Therapist - Time Slot (many-to-many)
model TherapistTimeSlot {
  id          String    @id @default(cuid())
  therapistId String
  timeSlotId  String
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  timeSlot    TimeSlot  @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  @@unique([therapistId, timeSlotId])
  @@map("therapist_time_slot")
}

/// Patient - Language (many-to-many)
model PatientLanguage {
  id         String   @id @default(cuid())
  patientId  String
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, languageId])
  @@map("patient_language")
}

/// Therapist - Language (many-to-many)
model TherapistLanguage {
  id          String    @id @default(cuid())
  therapistId String
  languageId  String
  language    Language  @relation(fields: [languageId], references: [id], onDelete: Cascade)
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, languageId])
  @@map("therapist_language")
}

/// Patient - Pathology (many-to-many)
model PatientPathology {
  id          String    @id @default(cuid())
  patientId   String
  pathologyId String
  pathology   Pathology @relation(fields: [pathologyId], references: [id], onDelete: Cascade)
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pathologyId])
  @@map("patient_pathology")
}

/// Therapist - Pathology expertise (many-to-many)
model TherapistPathology {
  id          String    @id @default(cuid())
  therapistId String
  pathologyId String
  pathology   Pathology @relation(fields: [pathologyId], references: [id], onDelete: Cascade)
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, pathologyId])
  @@map("therapist_pathology")
}

/// Therapist - Public Type (many-to-many)
model TherapistPublicType {
  id           String     @id @default(cuid())
  therapistId  String
  publicTypeId String
  publicType   PublicType @relation(fields: [publicTypeId], references: [id], onDelete: Cascade)
  therapist    Therapist  @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, publicTypeId])
  @@map("therapist_public_type")
}

/// Appointment
/// therapistAvailableTimeSlotId is OPTIONAL (String?) so that cancelled/completed/no_show
/// appointments can be detached when the therapist deletes the underlying time slot.
/// Active appointments (scheduled/confirmed) ALWAYS keep a valid slot reference.
model Appointment {
  id                           String                      @id @default(cuid())
  patientId                    String
  therapistId                  String
  therapistAvailableTimeSlotId String?                     @unique
  scheduledAt                  DateTime
  durationMinutes              Int                         @default(60)
  status                       String                      @default("scheduled")
  type                         String                      @default("video")
  notes                        String?
  cancelledAt                  DateTime?
  cancelledBy                  String?
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt
  patient                      Patient                     @relation(fields: [patientId], references: [id])
  therapistAvailableTimeSlot   TherapistAvailableTimeSlot? @relation(fields: [therapistAvailableTimeSlotId], references: [id])
  therapist                    Therapist                   @relation(fields: [therapistId], references: [id])
  appointmentOutcome           AppointmentOutcome?

  @@map("appointment")
}

model TherapistAvailableTimeSlot {
  id          String       @id @default(cuid())
  therapistId String
  startAt     DateTime
  endAt       DateTime
  isBooked    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  appointment Appointment?
  therapist   Therapist    @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId])
  @@index([startAt, endAt])
  @@map("therapist_available_timeslot")
}

/// Message
model Message {
  id             String    @id @default(cuid())
  senderId       String
  receiverId     String
  conversationId String    @map("roomId")
  content        String
  messageType    String    @default("text")
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  isDeleted      Boolean   @default(false)
  isEdited       Boolean   @default(false)
  therapist      User      @relation("TherapistMessages", fields: [receiverId], references: [id], onDelete: Cascade, map: "message_therapist_fkey")
  patient        User      @relation("PatientMessages", fields: [senderId], references: [id], onDelete: Cascade, map: "message_patient_fkey")

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@map("message")
}

/// Notification
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  actionUrl String?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("notification")
}

model AppointmentOutcome {
  id                 String      @id @default(cuid())
  appointmentId      String      @unique
  sessionNotes       String?
  interventionsUsed  String[]
  progressAssessment String?
  riskAssessment     String?
  isConfidential     Boolean     @default(true)
  rating             Int?
  comment            String?
  isAnonymous        Boolean     @default(false)
  isVisible          Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  appointment        Appointment @relation(fields: [appointmentId], references: [id])

  @@map("appointment_outcome")
}

/// Therapist change history — tracks every assignment so past
/// relationships are never lost. When a patient changes therapist:
/// 1. The previous entry (if any) gets unassignedAt = now()
/// 2. A new entry is created with assignedAt = now()
/// Past appointments stay linked via Appointment.therapistId.
model TherapistHistory {
  id           String    @id @default(cuid())
  patientId    String
  therapistId  String
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist    Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([therapistId])
  @@map("therapist_history")
}

/// Audit Log
model AuditLog {
  id            String   @id @default(cuid())
  actorId       String
  actorRole     String
  action        String
  resourceType  String
  resourceId    String?
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([actorId])
  @@index([resourceType])
  @@map("audit_log")
}

/// User roles for authentication and authorization
enum UserRole {
  PATIENT
  THERAPIST
  ADMIN
}

/// Patient preference for therapist gender
enum GenrePref {
  FEMME
  HOMME
  PEU_IMPORTE
}

/// Patient sensitivity preference (cultural/religious awareness)
enum SensibilitePatient {
  OUI_IMPORTANT
  NON_NECESSAIRE
  NE_SAIS_PAS
}

/// Patient's past therapy experience
enum ExperiencePassee {
  OUI_POSITIVE
  OUI_NON_SATISFAISANTE
  NON_PREMIERE_FOIS
  NE_SAIS_PAS
}

/// Patient's expectations for therapy style
enum AttentesTherapie {
  ECOUTE_ACTIVE
  EXERCICES_OUTILS
  COMPRENDRE_PASSE
  NE_SAIS_PAS
}

/// Therapist's sensitivity/cultural approach
enum SensibiliteTherapeute {
  INTEGRE_DEMANDE
  LAIQUE_NEUTRE
  AUTRE
}

/// Therapist's therapeutic approach
enum ApprocheTherapeute {
  TCC
  PSYCHANALYSE
  HUMANISTE_GESTALT
  INTEGRATIVE
}
