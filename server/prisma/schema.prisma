// Prisma Schema for Tassarut Platform
// Teleconsultation and Online Therapy Platform for Algeria

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// BETTER AUTH TABLES (Required for authentication)
// ============================================================================

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ============================================================================
// QUESTIONNAIRE ENUMS (Single-choice options)
// ============================================================================

/// Patient preference for therapist gender
enum GenrePref {
  FEMME       // Une femme
  HOMME       // Un homme
  PEU_IMPORTE // Peu importe
}

/// Patient sensitivity preference (cultural/religious awareness)
enum SensibilitePatient {
  OUI_IMPORTANT   // Oui, c'est important pour moi
  NON_NECESSAIRE  // Non, ce n'est pas nécessaire
  NE_SAIS_PAS     // Je ne sais pas
}

/// Patient's past therapy experience
enum ExperiencePassee {
  OUI_POSITIVE          // Oui, j'ai eu une expérience positive
  OUI_NON_SATISFAISANTE // Oui, mais l'expérience n'était pas satisfaisante
  NON_PREMIERE_FOIS     // Non, c'est ma première fois
  NE_SAIS_PAS           // Je ne sais pas
}

/// Patient's expectations for therapy style
enum AttentesTherapie {
  ECOUTE_ACTIVE      // Quelqu'un qui m'écoute activement sans trop intervenir
  EXERCICES_OUTILS   // Quelqu'un qui me donne des exercices et des outils concrets
  COMPRENDRE_PASSE   // Quelqu'un qui m'aide à comprendre mon passé en profondeur
  NE_SAIS_PAS        // Je ne sais pas encore
}

/// Therapist's sensitivity/cultural approach
enum SensibiliteTherapeute {
  INTEGRE_DEMANDE    // J'intègre explicitement ces dimensions à la demande
  LAIQUE_NEUTRE      // Mon approche est strictement laïque et neutre
  AUTRE              // Autre
}

/// Therapist's therapeutic approach
enum ApprocheTherapeute {
  TCC                // TCC (Exercices et outils concrets)
  PSYCHANALYSE       // Psychanalyse / Psychodynamique (Exploration du passé)
  HUMANISTE_GESTALT  // Humaniste / Gestalt (Écoute active)
  INTEGRATIVE        // Approche intégrative (Mélange)
}

// ============================================================================
// LOOKUP TABLES (Multi-select options)
// ============================================================================

/// Available consultation modes
model ConsultationMode {
  id    String @id @default(cuid())
  code  String @unique // visio, audio, presentiel
  label String

  patients   PatientConsultationMode[]
  therapists TherapistConsultationMode[]

  @@map("consultation_mode")
}

/// Available time slots
model TimeSlot {
  id    String @id @default(cuid())
  code  String @unique // matin, apres_midi, soiree, weekend
  label String

  patients   PatientTimeSlot[]
  therapists TherapistTimeSlot[]

  @@map("time_slot")
}

/// Available languages
model Language {
  id    String @id @default(cuid())
  code  String @unique // ar_darja, ar_fusha, tamazight, fr, en
  label String

  patients   PatientLanguage[]
  therapists TherapistLanguage[]

  @@map("language")
}

/// Available pathologies/issues
model Pathology {
  id    String @id @default(cuid())
  code  String @unique // stress_anxiete, depression, etc.
  label String

  patients   PatientPathology[]
  therapists TherapistPathology[]

  @@map("pathology")
}

/// Target audience types (therapist specialization)
model PublicType {
  id    String @id @default(cuid())
  code  String @unique // enfants_adolescents, adultes, couples, personnes_agees, tous_publics
  label String

  therapists TherapistPublicType[]

  @@map("public_type")
}

// ============================================================================
// TASSARUT PLATFORM TABLES
// ============================================================================

/// Patient Profile
model Patient {
  id                  String    @id @default(cuid())
  userId              String
  dateOfBirth         DateTime? @db.Date
  gender              String?
  phone               String?
  address             String?
  wilaya              String?
  emergencyContact    String?
  emergencyPhone      String?
  preferredLanguage   String?   @default("ar")
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  currentTherapistid String ?

  // Questionnaire single-choice responses (stored as enums)
  currentTherapist    Therapist? @relation(fields: [currentTherapistid], references: [id])
  genrePref           GenrePref?
  sensibilitePatient  SensibilitePatient?
  experiencePassee    ExperiencePassee?
  attentesTherapie    AttentesTherapie?

  // Legacy JSON backup (optional, for migration)
  questionnaireDataRaw Json? @map("questionnaire_data_raw")

  // Multi-select questionnaire relations
  consultationModes PatientConsultationMode[]
  timeSlots         PatientTimeSlot[]
  languages         PatientLanguage[]
  pathologies       PatientPathology[]

  // Other relations
  appointments   Appointment[]
  sessionReports SessionReport[]
  messages       Message[]       @relation("PatientMessages")
  reviews        Review[]

  @@map("patient")
}

/// Therapist Profile
model Therapist {
  id                   String   @id @default(cuid())
  userId               String
  licenseNumber        String?
  licenseVerified      Boolean  @default(false)
  yearsOfExperience    Int?
  education            String?
  bio                  String?
  profilePhotoUrl      String?
  hourlyRate           Decimal? @db.Decimal(10, 2)
  currency             String?  @default("DZD")
  availability         Json?
  acceptingNewPatients Boolean  @default(true)
  rating               Decimal? @db.Decimal(3, 2)
  totalReviews         Int      @default(0)
  verificationStatus   String   @default("pending")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Questionnaire single-choice responses (stored as enums)
  sensibiliteTherapeute SensibiliteTherapeute?
  approcheTherapeute    ApprocheTherapeute?

  // Multi-select questionnaire relations
  publicTypes       TherapistPublicType[]
  consultationModes TherapistConsultationMode[]
  timeSlots         TherapistTimeSlot[]
  languages         TherapistLanguage[]
  pathologies       TherapistPathology[]

  // Other relations
  patients Patient[]
  appointments   Appointment[]
  sessionReports SessionReport[]
  messages       Message[]       @relation("TherapistMessages")
  reviews        Review[]
  availableTimeSlots TherapistAvailableTimeSlot[]

  @@map("therapist")
}

// ============================================================================
// JOIN TABLES (Many-to-Many Relations)
// ============================================================================

/// Patient - Consultation Mode (many-to-many)
model PatientConsultationMode {
  id                 String @id @default(cuid())
  patientId          String
  consultationModeId String

  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultationMode ConsultationMode @relation(fields: [consultationModeId], references: [id], onDelete: Cascade)

  @@unique([patientId, consultationModeId])
  @@map("patient_consultation_mode")
}

/// Therapist - Consultation Mode (many-to-many)
model TherapistConsultationMode {
  id                 String @id @default(cuid())
  therapistId        String
  consultationModeId String

  therapist        Therapist        @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  consultationMode ConsultationMode @relation(fields: [consultationModeId], references: [id], onDelete: Cascade)

  @@unique([therapistId, consultationModeId])
  @@map("therapist_consultation_mode")
}

/// Patient - Time Slot (many-to-many)
model PatientTimeSlot {
  id         String @id @default(cuid())
  patientId  String
  timeSlotId String

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  @@unique([patientId, timeSlotId])
  @@map("patient_time_slot")
}

/// Therapist - Time Slot (many-to-many)
model TherapistTimeSlot {
  id          String @id @default(cuid())
  therapistId String
  timeSlotId  String

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  timeSlot  TimeSlot  @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  @@unique([therapistId, timeSlotId])
  @@map("therapist_time_slot")
}

/// Patient - Language (many-to-many)
model PatientLanguage {
  id         String @id @default(cuid())
  patientId  String
  languageId String

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([patientId, languageId])
  @@map("patient_language")
}

/// Therapist - Language (many-to-many)
model TherapistLanguage {
  id          String @id @default(cuid())
  therapistId String
  languageId  String

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  language  Language  @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([therapistId, languageId])
  @@map("therapist_language")
}

/// Patient - Pathology (many-to-many)
model PatientPathology {
  id          String @id @default(cuid())
  patientId   String
  pathologyId String

  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  pathology Pathology @relation(fields: [pathologyId], references: [id], onDelete: Cascade)

  @@unique([patientId, pathologyId])
  @@map("patient_pathology")
}

/// Therapist - Pathology expertise (many-to-many)
model TherapistPathology {
  id          String @id @default(cuid())
  therapistId String
  pathologyId String

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  pathology Pathology @relation(fields: [pathologyId], references: [id], onDelete: Cascade)

  @@unique([therapistId, pathologyId])
  @@map("therapist_pathology")
}

/// Therapist - Public Type (many-to-many)
model TherapistPublicType {
  id           String @id @default(cuid())
  therapistId  String
  publicTypeId String

  therapist  Therapist  @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  publicType PublicType @relation(fields: [publicTypeId], references: [id], onDelete: Cascade)

  @@unique([therapistId, publicTypeId])
  @@map("therapist_public_type")
}

// ============================================================================
// OTHER PLATFORM TABLES
// ============================================================================

/// Appointment
model Appointment {
  id                            String    @id @default(cuid())
  patientId                     String
  therapistId                   String
  
  // Add these two lines to establish the relation:
  therapistAvailableTimeSlotId  String    @unique // @unique ensures 1-to-1 relation
  therapistAvailableTimeSlot    TherapistAvailableTimeSlot @relation(fields: [therapistAvailableTimeSlotId], references: [id], onDelete: Restrict)

  // You can actually keep these for quick text queries, 
  // but you will populate them using the startAt/endAt of the slot!
  scheduledAt                   DateTime
  durationMinutes               Int       @default(60)
  
  status                        String    @default("scheduled")
  type                          String    @default("video")
  meetingUrl                    String?
  notes                         String?
  cancelledAt                   DateTime?
  cancelledBy                   String?
  cancellationReason            String?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  patient                       Patient   @relation(fields: [patientId], references: [id])
  therapist                     Therapist @relation(fields: [therapistId], references: [id])
  sessionReport                 SessionReport?
  review                       Review?

  @@map("appointment")
}

// Therapist available timeslots , to configure the interactive calendar 
model TherapistAvailableTimeSlot{
  id          String   @id @default(cuid())
  therapistId String
  startAt     DateTime
  endAt       DateTime
  isBooked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  
  // Add this line:
  appointment Appointment? 

  @@index([therapistId])
  @@index([startAt, endAt])
  @@map("therapist_available_timeslot")
}
/// Session Report
model SessionReport {
  id                 String   @id @default(cuid())
  appointmentId      String   @unique
  therapistId        String
  patientId          String
  sessionDate        DateTime
  presentingIssues   String?
  sessionNotes       String?
  interventionsUsed  String[]
  progressAssessment String?
  moodRating         Int?
  homeworkAssigned   String?
  nextSessionGoals   String?
  riskAssessment     String?
  isConfidential     Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  therapist   Therapist   @relation(fields: [therapistId], references: [id])
  patient     Patient     @relation(fields: [patientId], references: [id])

  @@map("session_report")
}

/// Message
model Message {
  id             String    @id @default(cuid())
  senderId       String
  receiverId     String
  conversationId String
  content        String
  messageType    String    @default("text")
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  patient   Patient?   @relation("PatientMessages", fields: [senderId], references: [id], map: "message_patient_fkey")
  therapist Therapist? @relation("TherapistMessages", fields: [receiverId], references: [id], map: "message_therapist_fkey")

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@map("message")
}

/// Notification
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  actionUrl String?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("notification")
}

/// Review
model Review {
  id            String   @id @default(cuid())
  patientId     String
  therapistId   String
  appointmentId String?
  rating        Int
  comment       String?
  isAnonymous   Boolean  @default(false)
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id])
  therapist   Therapist    @relation(fields: [therapistId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("review")
}

/// Audit Log
model AuditLog {
  id            String   @id @default(cuid())
  actorId       String
  actorRole     String
  action        String
  resourceType  String
  resourceId    String?
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([actorId])
  @@index([resourceType])
  @@map("audit_log")
}
